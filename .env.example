# CrossX Production Environment
# Copy to .env.local and fill in real values before starting the server.
# NEVER commit .env.local to git.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787
HOST=127.0.0.1          # keep 127.0.0.1 — Nginx proxies externally
APP_BASE_URL=https://your-domain.com
NODE_ENV=production
FORCE_HTTPS=1
PUBLIC_MODE=1
ADMIN_ALLOWED_IPS=127.0.0.1,10.0.0.

# ── Auth secrets (generate with: openssl rand -hex 32) ───────────────────────
ADMIN_SECRET_KEY=CHANGE_ME_32_HEX_CHARS
MERCHANT_AUTH_SECRET=CHANGE_ME_32_HEX_CHARS
USER_TOKEN_SECRET=CHANGE_ME_32_HEX_CHARS
MERCHANT_BOOTSTRAP_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# ── Security / compliance hard requirements for production ───────────────────
CROSSX_DB_ENCRYPTION_KEY=CHANGE_ME_LONG_RANDOM_SECRET
CROSSX_FIELD_ENC_SALT=CHANGE_ME_UNIQUE_DEPLOYMENT_SALT
CROSSX_CONSENT_STRICT=1

# ── AI — OpenAI (primary plan engine) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000

# ── AI — Anthropic (optional proxy, used by Claude Code) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Coze Bot (optional workflow fallback) ────────────────────────────────────
# COZE_API_KEY=pat_...
# COZE_BOT_API_KEY=sat_...
# COZE_API_BASE=https://api.coze.cn
# COZE_BOT_ID=
# COZE_WORKFLOW_ID=

# ── Amap (Gaode) — POI search, hotel lookup, routing ────────────────────────
AMAP_API_KEY=
AMAP_SECURITY_KEY=

# ── WeChat OAuth (optional login) ────────────────────────────────────────────
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# ── Payment — Alipay (optional, leave blank for QR sandbox) ─────────────────
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=

# ── Payment — WeChat Pay v3 (optional, leave blank for QR sandbox) ───────────
# WECHAT_MCH_ID=
# WECHAT_CERT_SERIAL_NO=
# WECHAT_PRIVATE_KEY=
# WECHAT_API_KEY_V3=
# WECHAT_NOTIFY_URL=https://your-domain.com/api/wechat/notify

# ── Data APIs ────────────────────────────────────────────────────────────────
# JUHE_KEY=
# JUHE_FLIGHT_KEY=

# ── Rail inventory provider (optional, can be separate from Partner Hub) ─────
# RAIL_KEY=
# RAIL_BASE_URL=https://your-rail-provider.example.com
# RAIL_PROVIDER=rail_provider
# RAIL_CHANNELS=rail
# RAIL_TIMEOUT_MS=5000

# ── SMS OTP (optional — dev mode sends code in API response if blank) ─────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1...

# ── Important ────────────────────────────────────────────────────────────────
# In production/public runtimes, startup security guards will fail closed if:
# - ADMIN_SECRET_KEY is missing
# - MERCHANT_AUTH_SECRET or ADMIN_SECRET_KEY is missing
# - USER_TOKEN_SECRET or ADMIN_SECRET_KEY is missing
# - MERCHANT_BOOTSTRAP_PASSWORD is missing
# - CROSSX_DB_ENCRYPTION_KEY is missing
# - CROSSX_FIELD_ENC_SALT is not uniquely configured
# - CROSSX_CONSENT_STRICT is not enabled
