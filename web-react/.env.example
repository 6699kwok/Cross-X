# CrossX React — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. NEVER commit real keys.
#
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# 高德地图 JS API 2.0
# 申请地址: https://console.amap.com/dev/key/app
# 需要开通的服务: Web端(JS API), 地点搜索(PlaceSearch)
VITE_AMAP_API_KEY=your_amap_web_api_key_here

# 高德安全密钥（AMap 2.0 必须，防止 key 被盗用）
# 在同一应用的"数字签名"页签获取
# 必须在 SDK script 加载前注入 window._AMapSecurityConfig
VITE_AMAP_SECURITY_KEY=your_amap_security_js_code_here
